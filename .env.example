APP_NAME=LunchMoneyPay
APP_VERSION=0.3.0
APP_ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CANONICAL_PUBLIC_ORIGIN=http://127.0.0.1:18531

# PostgreSQL uses a nonstandard host port to avoid project collisions.
DATABASE_URL=postgresql+psycopg://lunchmoneypay:lunchmoneypay@127.0.0.1:18533/lunchmoneypay

# Merchant API-key hashing. Replace before creating credentials.
API_KEY_PEPPER=replace-with-a-long-random-secret

# Development/test only. This endpoint accepts scenario controls, not card data.
DEMO_CHECKOUT_ENABLED=true
DEMO_CHECKOUT_EXPIRATION_YEAR=2099
